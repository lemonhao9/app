{
  "name": "homecyclhome-api",
  "version": "1.0.0",
  "description": "HomeCycl'Home — API REST + WebSocket",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "dev": "nodemon --legacy-watch src/index.js",
    "start": "node src/index.js",
    "test": "vitest run",
    "migrate": "node-pg-migrate -m migrations up",
    "migrate:create": "node-pg-migrate -m migrations create",
    "migrate:down": "node-pg-migrate -m migrations down 1",
    "test:coverage": "vitest run --coverage",
    "create-admin": "node src/scripts/createAdmin.js"
  },
  "dependencies": {
    "@turf/boolean-point-in-polygon": "^6.5.0",
    "@turf/helpers": "^6.5.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "jsonwebtoken": "^9.0.2",
    "node-pg-migrate": "^8.0.4",
    "pg": "^8.12.0",
    "socket.io": "^4.7.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "nodemon": "^3.1.4",
    "vitest": "^3.2.6"
  }
}
